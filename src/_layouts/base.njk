<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  {# SEO Meta Tags #}
  <title>{{ title }} | Aisha - Senior UX Designer & Consultant</title>
  <meta name="description" content="{{ description }}">
  
  {# Open Graph for social sharing #}
  <meta property="og:title" content="{{ title }} | Aisha - Senior UX Designer & Consultant">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://aisha.studio{{ page.url }}">
  
  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | Aisha - Senior UX Designer & Consultant">
  <meta name="twitter:description" content="{{ description }}">
  
  {# Canonical URL #}
  <link rel="canonical" href="https://aisha.studio{{ page.url }}">
  
  {# Stylesheet #}
  <link rel="stylesheet" href="/css/style.css">
  
  {# Structured Data for SEO #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Aisha",
    "jobTitle": "Senior UX Designer & Consultant",
    "url": "https://aisha.studio",
    "sameAs": [
      "https://www.linkedin.com/in/aisha"
    ],
    "knowsAbout": ["UX Design", "User Research", "UX Strategy", "Usability Testing", "UX Audit"],
    "hasOccupation": {
      "@type": "Occupation",
      "name": "UX Consultant",
      "occupationLocation": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Montpellier",
          "addressCountry": "FR"
        }
      }
    }
  }
  </script>
</head>
<body>
  
  <header>
    <nav>
      <a href="/" class="logo">Aisha</a>
      <ul>
        <li><a href="/">Work</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/work-with-me/">Work with Me</a></li>
      </ul>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <div class="connect">
      <h2>👋 Let's connect.</h2>
      <ul>
        <li><a href="mailto:hello@aisha.studio">Send a message</a></li>
        <li><a href="https://calendly.com/your-link">Schedule an intro call</a></li>
        <li><a href="https://www.linkedin.com/in/aisha">Find me on LinkedIn</a></li>
      </ul>
    </div>
    <p>&copy; {% year %} Aisha. All rights reserved.</p>
  </footer>

</body>
</html>
